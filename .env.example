OVERSHOOT_API_KEY=your_overshoot_key
GROQ_API_KEY=your_groq_key
OVERSHOOT_MODEL=Qwen/Qwen3-VL-32B-Instruct-FP8
OVERSHOOT_BASE_URL=https://api.overshoot.ai/v0.2
SCREENSHOT_INTERVAL=2000
MONITOR_INDEX=0
OUTPUT_DIR=./data
SAVE_SCREENSHOTS=false
WEBHOOK_URL=http://localhost:3000/poker-update
REGION_X=
REGION_Y=
REGION_WIDTH=
REGION_HEIGHT=

# Telegram countdown bot
TELEGRAM_BOT_TOKEN=
COUNTDOWN_START_DAYS=60
COUNTDOWN_SEND_HOUR=7
COUNTDOWN_TIMEZONE=Europe/Moscow
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
VERCEL_PROJECT_URL=https://your-project.vercel.app
# Fallback storage backend (works without Upstash)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
COUNTDOWN_STATE_ENV_KEY=COUNTDOWN_STATE_JSON
COUNTDOWN_STATE_ENV_TARGET=production

# Optional storage backend (preferred for scale)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
COUNTDOWN_CHATS_SET_KEY=countdown:chat_ids:v1
COUNTDOWN_CHAT_KEY_PREFIX=countdown:chat:v1:
